# Lemon Squeezy
LEMONSQUEEZY_API_KEY=ls_api_example_replace_me
LEMONSQUEEZY_WEBHOOK_SECRET=ls_webhook_secret_replace_me
LEMONSQUEEZY_STORE_ID=123456
LEMONSQUEEZY_STORE_URL=https://example-store.lemonsqueezy.com
LEMONSQUEEZY_CREATOR_VARIANT_ID=100001
LEMONSQUEEZY_PRO_VARIANT_ID=100002
